{
  "name": "turnzy-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile-iphone",
    "test:e2e:report": "playwright show-report",
    "ux-audit": "tsx e2e/ux-audit.ts",
    "ux-audit:screenshots-only": "SKIP_ANALYSIS=true tsx e2e/ux-audit.ts",
    "ux-audit:fast": "SKIP_ANALYSIS=true tsx e2e/ux-audit.ts",
    "test:qa": "playwright test e2e/scenarios",
    "test:qa:smoke": "playwright test e2e/scenarios/auth.spec.ts e2e/scenarios/host-dashboard.spec.ts --project=desktop",
    "test:qa:email": "playwright test e2e/scenarios/tokens.spec.ts --project=desktop",
    "test:qa:full": "playwright test e2e/scenarios --project=desktop",
    "test:qa:mobile": "playwright test e2e/scenarios --project=mobile-iphone",
    "test:qa:all-devices": "playwright test e2e/scenarios",
    "test:qa:gallery": "start e2e/screenshots/index.html",
    "test:qa:update-snapshots": "playwright test --update-snapshots",
    "test:qa:flows": "playwright test e2e/scenarios/E2E-flows.spec.ts --project=desktop",
    "test:qa:flows:headed": "playwright test e2e/scenarios/E2E-flows.spec.ts --project=desktop --headed"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-toast": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.6.0",
    "express": "^4.18.0",
    "lucide-react": "^0.300.0",
    "react": "^18.3.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "workbox-window": "^7.0.0"
  }
}
